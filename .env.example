# ==============================
# SERVER CONFIGURATION
# ==============================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5500

# ==============================
# DATABASE
# ==============================
# Get this from MongoDB Atlas: Database > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# ==============================
# EMAIL (NODEMAILER)
# ==============================
# If using Gmail, generate an App Password (not your regular password):
# https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_RECEIVER=your-email@gmail.com

# ==============================
# SECURITY
# ==============================
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate limiter: max contact form submissions per IP per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5